[general]
theme = "default"
debug = true
first_run = true

[display]
invert = true
driver = "only_web"
timeout = 10

[display_cast]
default = false
streaming = "ffmpeg"

[network]
interface = false
ask_interface = false

[bluetooth]
interface = false
ask_interface = false

[pheripherals]
enable_keyboard = true
enable_pins = false
enable_web = false


[plugins]
enabled = true
folder = "./plugins"
